# API server
API_HOST=0.0.0.0
API_PORT=8080
API_TLS_CERT=./.private/certs/localhost.pem
API_TLS_KEY=./.private/certs/localhost-key.pem

# UI server
UI_HOST=0.0.0.0
UI_PORT=3000

# Workers
WORKER_CONCURRENCY=1

# Redis (run with: docker compose up redis -d)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# MongoDB (run with: docker compose up mongodb -d)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=immaiwin

# Schwab
SCHWAB_CLIENT_ID=your_client_id
SCHWAB_CLIENT_SECRET=your_client_secret
SCHWAB_CALLBACK_URL=https://127.0.0.1:8080/auth/schwab/callback

# Polymarket watcher (run with: make run-worker NAME=polymarket-watcher)
# Number of past trades tracked per asset for the rolling average (default: 20).
POLYMARKET_WINDOW_SIZE=20
# Flag a trade when its size exceeds this multiple of the rolling average (default: 3.0).
POLYMARKET_SIZE_MULTIPLIER=3.0
# Always flag a trade when its size (in USDC) meets or exceeds this value (default: 10000).
POLYMARKET_MIN_ABSOLUTE_SIZE=10000
